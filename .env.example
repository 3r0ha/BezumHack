# Database
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform_secret
POSTGRES_DB=platform

# Auth
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://redis:6379

# AI Service — YandexGPT (primary)
AI_PROVIDER=yandex
YANDEX_API_KEY=your-yandex-api-key
YANDEX_FOLDER_ID=your-folder-id
YANDEX_MODEL=yandexgpt/latest

# AI Service — Anthropic (fallback)
AI_API_KEY=your-anthropic-key
AI_MODEL=claude-sonnet-4-20250514

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token

# Services (internal)
AUTH_SERVICE_URL=http://auth:3001
PROJECTS_SERVICE_URL=http://projects:3002
CHAT_SERVICE_URL=http://chat:3003
AI_SERVICE_URL=http://ai:3004
NOTIFICATIONS_SERVICE_URL=http://notifications:3005
